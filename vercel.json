{
  "regions": ["fra1"],
  "functions": {
    "api/mexc-ticker.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/telegram-scrape",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/delete-old-events",
      "schedule": "0 3 * * *"
    }
  ]
}
